PROJECT_NAME=IT News Platform
APP_ENV=local
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=INFO

POSTGRES_DB=itnews
POSTGRES_USER=itnews
POSTGRES_PASSWORD=itnews
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

REDIS_URL=redis://redis:6379/0

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=news_articles

ENABLE_SCHEDULER=true
INGESTION_INTERVAL_MINUTES=30
EMBEDDING_INDEX_INTERVAL_MINUTES=5
CLUSTERING_INTERVAL_MINUTES=30
ENABLE_NEWS_API=false
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_KEY=
NEWS_API_QUERY=technology OR cybersecurity OR software

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=ru,en
ALLOWED_RSS_SOURCES=https://techcrunch.com/feed/,https://www.wired.com/feed/rss,https://feeds.arstechnica.com/arstechnica/index
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_MAX_CHARS=4000
EMBEDDING_MAX_RETRIES=3
CLUSTERING_HDBSCAN_THRESHOLD=50
CLUSTERING_MIN_CLUSTER_SIZE=5
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_TIMEOUT_SECONDS=45
RAG_TOP_K=5
GRAPH_MAX_ENTITIES=15
GRAPH_MAX_RELATIONS=20
RAG_MAX_ARTICLE_SNIPPET_CHARS=700
RAG_CONTEXT_TOKEN_BUDGET=8000
