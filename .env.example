PROJECT_NAME=IT News Platform
APP_ENV=local
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000
LOG_LEVEL=INFO

POSTGRES_DB=itnews
POSTGRES_USER=itnews
POSTGRES_PASSWORD=itnews
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

REDIS_URL=redis://redis:6379/0

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=articles

ENABLE_SCHEDULER=true
INGESTION_INTERVAL_MINUTES=30
ENABLE_NEWS_API=false
NEWS_API_URL=https://newsapi.org/v2/everything
NEWS_API_KEY=
NEWS_API_QUERY=technology OR cybersecurity OR software

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=ru,en
ALLOWED_RSS_SOURCES=https://techcrunch.com/feed/,https://www.wired.com/feed/rss,https://feeds.arstechnica.com/arstechnica/index
